rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 확인 함수
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 로그인 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 여부 확인
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // users 컬렉션
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // recommendations 서브컬렉션 (Functions에서만 쓰기)
      match /recommendations/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      // trustVotes 서브컬렉션 (users/{uid}/trustVotes/{voteId})
      match /trustVotes/{voteId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.voterUid == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.voterUid == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.voterUid == request.auth.uid || isAdmin());
      }

      // bookmarks 서브컬렉션 (users/{uid}/bookmarks/{postId})
      match /bookmarks/{bookmarkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // posts 컬렉션
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // posts/{postId}/comments 서브컬렉션
    match /posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // comments 컬렉션 그룹 읽기 (관리자 페이지용)
    match /{path=**}/comments/{commentId} {
      allow read: if isAuthenticated();
    }

    // chatRooms 컬렉션
    match /chatRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // reports 컬렉션 (신고)
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // notifications 컬렉션 (notifications/{uid}/items/{itemId} 구조)
    match /notifications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /items/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // errorLogs 컬렉션
    match /errorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // schools 컬렉션 (마스터)
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // sanctions 컬렉션
    match /sanctions/{sanctionId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // adminMemos 컬렉션
    match /adminMemos/{memoId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // adminLogs 컬렉션
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // adminAlerts 컬렉션
    match /adminAlerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // stories 컬렉션
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // meetups 컬렉션
    match /meetups/{meetupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.hostUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.hostUid == request.auth.uid || isAdmin());
    }

    // jobs 컬렉션
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // connections 컬렉션
    match /connections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || isAdmin());
    }

    // verificationRequests 컬렉션
    match /verificationRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // policies 컬렉션 (약관 - 비로그인도 읽기 가능)
    match /policies/{policyId} {
      allow read: if true;
      allow write: if request.auth != null && (
        isAdmin() ||
        request.auth.token.email == 'airlkh80@gmail.com'
      );

      match /versions/{versionId} {
        allow read: if request.auth != null && (isAdmin() || request.auth.token.email == 'airlkh80@gmail.com');
        allow create: if request.auth != null && (isAdmin() || request.auth.token.email == 'airlkh80@gmail.com');
        allow update: if false;
        allow delete: if false;
      }
    }

    // music 컬렉션
    match /music/{musicId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 나머지 관리자 전용 컬렉션
    match /{collection}/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
