{
  "expo": {
    "name": "Again School",
    "slug": "again-school",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "again-school",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF3124"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.againschool.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.againschool.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "adjustResize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF3124"
      },
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "again-school",
              "path": "oauth2redirect/google"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "?пњљл°Ь???пњљмІД???пњљм†Х?пњљкЄ∞ ?пњљнХі ?пњљмІД ?пњљкЈЉ кґМнХЬ???пњљмЪФ?пњљлЛИ??"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF3124"
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "к∞§лЯђл¶ђмЧР???пњљмІДпњљ??пњљмШБ?пњљмЭД ?пњљнГЭ?пњљкЄ∞ ?пњљнХі ?пњљкЈЉ кґМнХЬ???пњљмЪФ?пњљлЛИ??",
